# Arquivo: .env.example
# Copie este arquivo para .env e preencha com seus próprios valores.
# NUNCA envie o arquivo .env para o repositório (contém segredos).

# -----------------------------
# PostgreSQL (API, Worker e Kong)
# -----------------------------
POSTGRES_DB=sinapi
POSTGRES_USER=sinapi
POSTGRES_PASSWORD=changeme_postgres_password

# -----------------------------
# Kong (API Gateway) - usa o mesmo Postgres
# -----------------------------
KONG_PG_USER=kong
KONG_PG_PASSWORD=changeme_kong_password
KONG_PG_HOST=db

# -----------------------------
# Redis (cache / locks)
# -----------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------
# Celery / Broker (usando Redis)
# -----------------------------
CELERY_BROKER_URL=redis://redis:6379/0

# -----------------------------
# Configs da API
# -----------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------------
# Opcional: Cloudflare Tunnel (removido por padrão)
# -----------------------------
CLOUDFLARE_TUNNEL_TOKEN=

# -----------------------------
# Outras (opcionais)
# -----------------------------
LOG_LEVEL=INFO
SENTRY_DSN=